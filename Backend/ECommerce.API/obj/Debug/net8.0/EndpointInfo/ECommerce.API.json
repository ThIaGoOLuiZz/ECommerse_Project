{
  "openapi": "3.0.1",
  "info": {
    "title": "ECommerce.API",
    "version": "1.0"
  },
  "paths": {
    "/api/User": {
      "post": {
        "tags": [
          "User"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserRequestDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UserRequestDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UserRequestDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "UserRequestDTO": {
        "required": [
          "mail",
          "name",
          "password",
          "phone",
          "userType"
        ],
        "type": "object",
        "properties": {
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "mail": {
            "minLength": 1,
            "type": "string"
          },
          "phone": {
            "type": "integer",
            "format": "int32"
          },
          "userType": {
            "$ref": "#/components/schemas/UserTypeEnum"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "UserTypeEnum": {
        "enum": [
          0,
          1
        ],
        "type": "integer",
        "format": "int32"
      }
    }
  }
}